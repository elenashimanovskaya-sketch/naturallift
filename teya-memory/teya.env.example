# Teya secrets template.
# Copy to: teya-memory/teya.env.local
# Do not commit teya.env.local.
#
# Fill only what you have. If a section is empty, Teya will work locally and stop before publishing.

# -----------------------------------------------------------------------------
# 1. Site / WordPress
# -----------------------------------------------------------------------------
PUBLIC_SITE_URL=https://example.com
WP_ADMIN_URL=https://example.com/wp-admin
WP_ADMIN_USER=
WP_ADMIN_PASSWORD=
WP_APP_PASSWORD=
WP_THEME_SLUG=teya-generated-site

# If WP-CLI is available on hosting via SSH, set yes.
WP_CLI_AVAILABLE=unknown

# -----------------------------------------------------------------------------
# 2. Deployment Mode
# -----------------------------------------------------------------------------
# local-only | ftp | sftp | ssh
TEYA_DEPLOY_MODE=local-only

# Safety switches. Keep "no" until you are ready.
TEYA_ALLOW_PUBLISH=no
TEYA_ALLOW_ACTIVATE_THEME=no
TEYA_ALLOW_CREATE_PAGES=yes
TEYA_ALLOW_CREATE_POSTS=yes
TEYA_ALLOW_CLEAR_CACHE=yes

# -----------------------------------------------------------------------------
# 3. FTP
# -----------------------------------------------------------------------------
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASS=
# Path is relative to FTP root. If FTP login already opens public_html, use:
FTP_REMOTE_THEME_PATH=/wp-content/themes/teya-generated-site
# If FTP root is one level above public_html, use:
# FTP_REMOTE_THEME_PATH=/public_html/wp-content/themes/teya-generated-site

# -----------------------------------------------------------------------------
# 4. SFTP / SSH
# -----------------------------------------------------------------------------
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_PASS=
SSH_KEY_PATH=
SSH_THEME_PATH=/home/user/public_html/wp-content/themes/teya-generated-site

# -----------------------------------------------------------------------------
# 5. Database / Hosting Panel (optional)
# -----------------------------------------------------------------------------
HOSTING_PANEL_URL=
HOSTING_PANEL_USER=
HOSTING_PANEL_PASSWORD=
HOSTING_PROVIDER=

DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=3306

# -----------------------------------------------------------------------------
# 6. SMTP / Email Delivery (optional, for forms)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_SECURE=tls

# -----------------------------------------------------------------------------
# 7. Notifications / CRM (optional)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CRM_WEBHOOK_URL=
WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# 8. Analytics / Verification (optional)
# -----------------------------------------------------------------------------
GA4_MEASUREMENT_ID=
GTM_CONTAINER_ID=
YANDEX_METRIKA_COUNTER_ID=
GOOGLE_SITE_VERIFICATION=
YANDEX_SITE_VERIFICATION=

# -----------------------------------------------------------------------------
# 9. Business Listings / Maps (optional)
# -----------------------------------------------------------------------------
YANDEX_BUSINESS_URL=
GOOGLE_BUSINESS_PROFILE_URL=
TWOGIS_URL=
MAPS_EMBED_URL=

# -----------------------------------------------------------------------------
# 10. MCP / External APIs (optional)
# -----------------------------------------------------------------------------
# Usually Cursor stores MCP auth separately. Add only if your setup needs env vars.
MCP_KV_API_KEY=
YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_FOLDER_ID=

# -----------------------------------------------------------------------------
# 11. Backups / Rollback (optional but recommended before publish)
# -----------------------------------------------------------------------------
BACKUP_BEFORE_DEPLOY=yes
BACKUP_PATH=
ROLLBACK_KEEP_RELEASES=3
